# Flask secret key — used to sign session cookies and CSRF tokens.
#
# Generate a strong random key with:
#   python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=

# Ambiente da aplicação: "development" ou "production"
FLASK_ENV=development

# Número de workers do Gunicorn (default: 2 * CPU cores + 1)
# GUNICORN_WORKERS=5

# Bind do Gunicorn (default: unix:/run/gunicorn.sock)
# GUNICORN_BIND=127.0.0.1:8000

# Diretório raiz contendo as pastas "Fotos anatomia", "Fotos Histologia"
# e "Fotos microbiologia" usadas pelo importador.
IMPORT_SOURCE_DIR=